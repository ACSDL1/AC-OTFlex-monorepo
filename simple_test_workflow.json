                        "offsetY": 0,
                        "offsetZ": 20
                    },
                    "action": "liquid",
                    "volume_uL": 50,
                    "move_speed": 120,
                    "pipette": "p50_single_flex",
                    "tiprack": "tiprack_50ul"
                }
            },
            {
                "id": "output",
                "type": "output",
                "label": "End Node",
                "params": {}
            }
        ],
        "edges": [
            {
                "id": "start-to-close",
                "source": "1",
                "target": "liquid_transfer_to_reactor",
                "type": "default"
            },
            {
                "id": "flush-to-output",
                "source": "liquid_transfer_to_reactor",
                "target": "output",
                "type": "default"
            }
        ],
        "executionMetadata": {
