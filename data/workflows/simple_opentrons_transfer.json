{
  "name": "Simple Opentrons Transfer",
  "description": "Transfer liquid from one well to the reactor, then lift the reactor via MQTT",
  "version": "1.1.0",
  "author": "AC-OTFlex",
  "created": "2026-03-04",
  "workflow": {
    "nodes": [
      {
        "id": "start",
        "type": "input",
        "label": "Start",
        "params": {}
      },
      {
        "id": "transfer_1",
        "type": "otflexTransfer",
        "label": "Transfer Liquid to Reactor",
        "params": {
          "from": {
            "labware": "source_plate",
            "well": "B2",
            "offsetX": 0,
            "offsetY": 0,
            "offsetZ": 5
          },
          "to": {
            "labware": "destination_plate",
            "well": "B1",
            "offsetX": 0,
            "offsetY": 0,
            "offsetZ": 20
          },
          "volume_uL": 500,
          "move_speed": 120,
          "pipette": "p1000_single_flex",
          "tiprack": "tiprack_1000ul"
        }
      },
      {
        "id": "reactor_lift",
        "type": "mqttReactor",
        "label": "Reactor Lift",
        "params": {
          "direction": "forward",
          "duration_ms": 3000,
          "resourceLocks": [
            "reactor:01"
          ]
        }
      },
      {
        "id": "end",
        "type": "output",
        "label": "End",
        "params": {}
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "start",
        "target": "transfer_1",
        "type": "default"
      },
      {
        "id": "e2",
        "source": "transfer_1",
        "target": "reactor_lift",
        "type": "default"
      },
      {
        "id": "e3",
        "source": "reactor_lift",
        "target": "end",
        "type": "default"
      }
    ]
  },
  "devices": {
    "otflex": {
      "module": "otflex_runtime.py",
      "controller_ip": "169.254.179.32",
      "deck": {
        "slots": {
          "B1": {
            "name": "destination_plate",
            "display": "destination",
            "labware": "actuated_reactor",
            "file": "data/labware_definitions/actuated_reactor.json",
            "slot_label": "B1"
          },
          "B2": {
            "name": "source_plate",
            "display": "source",
            "labware": "11_vials_20mL",
            "file": "data/labware_definitions/sdl1_11_vials_20mL.json",
            "slot_label": "B2"
          },
          "C3": {
            "name": "tiprack_1000ul",
            "display": "tiprack_1000ul",
            "labware": "opentrons_flex_96_tiprack_1000ul",
            "slot_label": "C3"
          }
        },
        "pipettes": {
          "right": {
            "model": "p1000_single_flex"
          }
        }
      }
    },
    "mqtt": {
      "broker": "localhost",
      "port": 1883,
      "username": "pyctl-controller",
      "password": "controller",
      "topics": {
        "reactor": "reactor/01"
      }
    }
  }
}
