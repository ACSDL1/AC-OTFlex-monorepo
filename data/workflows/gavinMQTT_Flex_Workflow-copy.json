{
	"name": "Gavin MQTT + OTFlex Electrode Workflow",
	"description": "Raise/lower autoreactor, dose each precursor into reactor column 1 using one tip per precursor, place the 4-electrode tool, flush A1/B1 with pump cycles, run potentiostat probing, then run furnace door sequence.",
	"version": "1.2.0",
	"author": "AC-OTFlex",
	"created": "2026-03-10",
	"workflow": {
		"nodes": [
			{
				"id": "step0",
				"type": "input",
				"label": "Start",
				"params": {}
			},
			{
				"id": "step1",
				"type": "mqttReactor",
				"label": "Raise autoreactor (5s)",
				"params": {
					"direction": "forward",
					"duration_ms": 5000,
					"resourceLocks": [
						"reactor:01"
					]
				}
			},
			{
				"id": "step2",
				"type": "mqttWait",
				"label": "Pause 5 seconds",
				"params": {
					"duration_s": 5,
					"resourceLocks": [
						"reactor:01"
					]
				}
			},
			{
				"id": "step3",
				"type": "mqttReactor",
				"label": "Lower autoreactor (8s)",
				"params": {
					"direction": "reverse",
					"duration_ms": 8000,
					"resourceLocks": [
						"reactor:01"
					]
				}
			},
			{
				"id": "step4",
				"type": "otflexTransfer",
				"label": "Precursor 1 to column 1 (A1 then B1, one tip)",
				"params": {
					"from": {
						"labware": "precursor_solutions",
						"well": "A1",
						"offsetX": 0,
						"offsetY": 0,
						"offsetZ": 5
					},
					"to": {
						"labware": "autreactor",
						"well": [
							"A1",
							"B1"
						],
						"offsetX": 0,
						"offsetY": 0,
						"offsetZ": 20
					},
					"volume_uL": 500,
					"move_speed": 120,
					"pipette": "p1000_single_flex",
					"tiprack": "tiprack_1000ul",
					"autopick_tip": true
				}
			},
			{
				"id": "step5",
				"type": "otflexTransfer",
				"label": "Precursor 2 to column 1 (A1 then B1, new tip)",
				"params": {
					"from": {
						"labware": "precursor_solutions",
						"well": "A2",
						"offsetX": 0,
						"offsetY": 0,
						"offsetZ": 5
					},
					"to": {
						"labware": "autreactor",
						"well": [
							"A1",
							"B1"
						],
						"offsetX": 0,
						"offsetY": 0,
						"offsetZ": 20
					},
					"volume_uL": 500,
					"move_speed": 120,
					"pipette": "p1000_single_flex",
					"tiprack": "tiprack_1000ul",
					"autopick_tip": true
				}
			},
			{
				"id": "step6",
				"type": "otflexToolTransfer",
				"label": "Pick 4-electrode tool and place into reactor column 1",
				"params": {
					"from": {
						"labware": "parallel_electrode_module",
						"well": "A1",
						"offsetX": 0.5,
						"offsetY": 1.0,
						"offsetZ": 0.0
					},
					"to": {
						"labware": "autreactor",
						"well": "A1",
						"offsetX": -3.5,
						"offsetY": -34.5,
						"offsetZ": 10.0
					},
					"pipette": "p1000_single_flex",
					"move_speed": 80,
					"approach_offset_z": 0.0,
					"insert_pause_s": 1.0,
					"return_dZ": 12.0
				}
			},
			{
				"id": "step7",
				"type": "otflexFlushWell",
				"label": "Flush tool (middle rack C1): rinse A1 then B1 (2 cycles each)",
				"params": {
					"from": {
						"labware": "single_electrode_module",
						"well": "C1",
						"offsetX": 0.0,
						"offsetY": 0.0,
						"offsetZ": 0.0
					},
					"to": {
						"labware": "autreactor",
						"well": [
							"A1",
							"B1"
						],
						"offsetX": 0,
						"offsetY": 0,
						"offsetZ": 5.0
					},
					"pipette": "p1000_single_flex",
					"in_pump_id": 1,
					"out_pump_id": 3,
					"time_ms": 3000,
					"repeats": 2,
					"purge_ms": 0,
					"return_dZ": 12.0,
					"resourceLocks": [
						"reactor:01"
					]
				}
			},
			{
				"id": "step8",
				"type": "sdl1ElectrochemicalMeasurement",
				"label": "Run potentiostat probe on column 1",
				"params": {
					"uo_name": "PotentiostatProbe_Col1",
					"measurement_type": "probe",
					"resourceLocks": [
						"reactor:01"
					]
				}
			},
			{
				"id": "step9",
				"type": "mqttReactor",
				"label": "Raise autoreactor (final)",
				"params": {
					"direction": "forward",
					"duration_ms": 5000,
					"resourceLocks": [
						"reactor:01"
					]
				}
			},
			{
				"id": "step10",
				"type": "mqttFurnace",
				"label": "Open furnace door",
				"params": {
					"action": "open",
					"duration_ms": 6400,
					"resourceLocks": [
						"furnace:01"
					]
				}
			},
			{
				"id": "step11",
				"type": "mqttWait",
				"label": "Pause 10 seconds",
				"params": {
					"duration_s": 10,
					"resourceLocks": [
						"furnace:01"
					]
				}
			},
			{
				"id": "step12",
				"type": "mqttFurnace",
				"label": "Close furnace door",
				"params": {
					"action": "close",
					"duration_ms": 10000,
					"resourceLocks": [
						"furnace:01"
					]
				}
			},
			{
				"id": "step13",
				"type": "output",
				"label": "End",
				"params": {}
			}
		],
		"edges": [
			{
				"id": "e1",
				"source": "step0",
				"target": "step1",
				"type": "default"
			},
			{
				"id": "e2",
				"source": "step1",
				"target": "step2",
				"type": "default"
			},
			{
				"id": "e3",
				"source": "step2",
				"target": "step3",
				"type": "default"
			},
			{
				"id": "e4",
				"source": "step3",
				"target": "step4",
				"type": "default"
			},
			{
				"id": "e5",
				"source": "step4",
				"target": "step5",
				"type": "default"
			},
			{
				"id": "e6",
				"source": "step5",
				"target": "step6",
				"type": "default"
			},
			{
				"id": "e7",
				"source": "step6",
				"target": "step7",
				"type": "default"
			},
			{
				"id": "e8",
				"source": "step7",
				"target": "step8",
				"type": "default"
			},
			{
				"id": "e9",
				"source": "step8",
				"target": "step9",
				"type": "default"
			},
			{
				"id": "e10",
				"source": "step9",
				"target": "step10",
				"type": "default"
			},
			{
				"id": "e11",
				"source": "step10",
				"target": "step11",
				"type": "default"
			},
			{
				"id": "e12",
				"source": "step11",
				"target": "step12",
				"type": "default"
			},
			{
				"id": "e13",
				"source": "step12",
				"target": "step13",
				"type": "default"
			}
		]
	},
	"devices": {
		"otflex": {
			"module": "otflex_runtime.py",
			"controller_ip": "169.254.179.32",
			"deck": {
				"slots": {
					"A1": {
						"name": "single_electrode_module",
						"display": "3 electrodes",
						"labware": "sdl1_single_electrode_tiprack",
						"file": "data/labware_definitions/sdl1_single_electrode_tiprack.json",
						"slot_label": "A1"
					},
					"A2": {
						"name": "parallel_electrode_module",
						"display": "4 electrode tool",
						"labware": "sdl1_parallel_electrode_tiprack",
						"file": "data/labware_definitions/sdl1_parallel_electrode_tiprack.json",
						"slot_label": "A2"
					},
					"A3": {
						"name": "trash",
						"display": "trash",
						"labware": "opentrons_flex_trash",
						"slot_label": "A3"
					},
					"B1": {
						"name": "autreactor",
						"display": "autreactor",
						"labware": "actuated_reactor",
						"file": "data/labware_definitions/actuated_reactor.json",
						"slot_label": "B1"
					},
					"B2": {
						"name": "precursor_solutions",
						"display": "precursor solutions",
						"labware": "sdl1_11_vials_20mL",
						"file": "data/labware_definitions/sdl1_11_vials_20mL.json",
						"slot_label": "B2"
					},
					"C3": {
						"name": "tiprack_1000ul",
						"display": "1000ul tips",
						"labware": "opentrons_flex_96_tiprack_1000ul",
						"slot_label": "C3"
					},
					"D1": {
						"name": "substrate_tower",
						"display": "tower of substrates",
						"labware": "zou_21_wellplate_4500ul",
						"file": "data/labware_definitions/zou_21_wellplate_4500ul.json",
						"slot_label": "D1"
					}
				},
				"pipettes": {
					"right": {
						"model": "p1000_single_flex"
					}
				}
			}
		},
		"potentiostat": {
			"ports": [
				"/dev/ttyACM0",
				"/dev/ttyACM1",
				"/dev/ttyACM2",
				"/dev/ttyACM3"
			],
			"baudrate": 115200,
			"timeout_s": 2.0,
			"device_id": 1,
			"strict": false
		},
		"mqtt": {
			"broker": "localhost",
			"port": 1883,
			"username": "pyctl-controller",
			"password": "controller",
			"topics": {
				"pumps": "pumps/01",
				"reactor": "reactor/01",
				"furnace": "furnace/01"
			}
		}
	}
}
